{
  "name": "@jobscheduler/server",
  "version": "1.0.0",
  "private": true,
  "description": "Distributed job scheduler - REST API and worker service",
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/api/main.ts",
    "api": "tsx src/api/main.ts",
    "worker": "tsx src/worker/main.ts",
    "seed": "tsx src/db/seed.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cron-parser": "^4.9.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "pino": "^9.6.0",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
